{
  // ═══════════════════════════════════════════════════════════════════════════
  // CONFIGURACIÓN OPTIMIZADA PARA FLUTTER
  // Excluye código nativo (Android/iOS) del análisis para evitar warnings
  // ═══════════════════════════════════════════════════════════════════════════
  
  // Excluir carpetas nativas del explorador (más limpio)
  "files.exclude": {
    "**/.dart_tool": true,
    "**/.flutter-plugins": true,
    "**/.flutter-plugins-dependencies": true,
    "**/generated_plugin_registrant.dart": true
  },
  
  // Excluir carpetas nativas del ANÁLISIS (evita warnings de Gradle/Swift)
  "files.watcherExclude": {
    "**/android/**": true,
    "**/ios/**": true,
    "**/web/**": true,
    "**/linux/**": true,
    "**/macos/**": true,
    "**/windows/**": true,
    "**/.dart_tool/**": true,
    "**/build/**": true,
    "**/.gradle/**": true
  },
  
  // Configuración del Dart Analysis Server (el que SÍ importa)
  "dart.analysisServerFolding": true,
  "dart.lineLength": 100,
  "dart.enableSdkFormatter": true,
  
  // Desactivar análisis de archivos que no son Dart/Flutter
  "files.associations": {
    "*.dart": "dart"
  },
  
  // Excluir búsquedas en carpetas nativas
  "search.exclude": {
    "**/android/**": true,
    "**/ios/**": true,
    "**/web/**": true,
    "**/linux/**": true,
    "**/macos/**": true,
    "**/windows/**": true,
    "**/.dart_tool/**": true,
    "**/build/**": true,
    "**/.gradle/**": true,
    "**/node_modules": true
  }
}
