<?xml version="1.0" encoding="utf-8"?>
<!--
  JesusWidget layout — matches in‑app JesusStreakWidget pixel‑for‑pixel.
  Designed for 3×2 (default), resizable to 4×2 / 5×2 / 3×3 / 4×3.
  Kotlin provider handles dynamic sizing via AppWidgetManager.getAppWidgetOptions.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/jesus_widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="@drawable/jesus_widget_background">

    <!-- CAPA 1: Fondo dinámico (imagen según racha) -->
    <ImageView
        android:id="@+id/widget_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- CAPA 2: Gradiente oscuro L→R (legibilidad) -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/jesus_widget_gradient"
        android:contentDescription="@null" />

    <!-- CAPA 3: Contenido — Row(sprite | info column) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:paddingStart="4dp"
        android:paddingEnd="10dp">

        <!-- ── Sprite de Jesús (izquierda) ── -->
        <ImageView
            android:id="@+id/widget_jesus_image"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="38"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:clipToPadding="false"
            android:contentDescription="Jesús" />

        <!-- ── Columna derecha: streak + mensaje + botón ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="62"
            android:orientation="vertical"
            android:paddingStart="2dp"
            android:gravity="start">

            <!-- ─── FILA: 🔥 7  DÍAS  ✓Hoy ─── -->
            <LinearLayout
                android:id="@+id/widget_streak_block"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Icono fuego -->
                <ImageView
                    android:id="@+id/widget_fire_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="4dp"
                    android:src="@drawable/ic_fire"
                    android:contentDescription="@null" />

                <!-- Número grande (Cinzel serif = match in-app) -->
                <TextView
                    android:id="@+id/widget_streak_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFFFF"
                    android:textSize="46sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/cinzel"
                    android:includeFontPadding="false"
                    android:shadowColor="#88000000"
                    android:shadowDx="1"
                    android:shadowDy="2"
                    android:shadowRadius="4" />

                <!-- DÍAS / DE VICTORIA -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_marginBottom="8dp"
                    android:layout_gravity="bottom"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/widget_streak_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DÍAS"
                        android:textColor="#FF69F0AE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:includeFontPadding="false"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/widget_streak_sublabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-1dp"
                        android:text="DE VICTORIA"
                        android:textColor="#99FFFFFF"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:includeFontPadding="false" />

                </LinearLayout>

                <!-- Badge "✓ Hoy" -->
                <TextView
                    android:id="@+id/widget_hoy_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_marginBottom="10dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/jesus_hoy_badge_bg"
                    android:paddingStart="6dp"
                    android:paddingEnd="7dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="✓ Hoy"
                    android:textColor="#FF4CAF50"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:includeFontPadding="false"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- ─── Mensaje motivacional ─── -->
            <TextView
                android:id="@+id/widget_message"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="4dp"
                android:text=""
                android:textColor="#E6FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="3"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.2"
                android:gravity="top"
                android:shadowColor="#88000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="3" />

            <!-- ─── Botón de acción (pill dorado) ─── -->
            <TextView
                android:id="@+id/widget_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="2dp"
                android:background="@drawable/jesus_badge_background"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:text="Empieza hoy"
                android:textColor="#FFD4AF37"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
