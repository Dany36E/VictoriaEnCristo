<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/jesus_widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/jesus_widget_background">

    <!-- Fondo dinámico (imagen según racha) -->
    <ImageView
        android:id="@+id/widget_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Gradiente sutil L→R -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/jesus_widget_gradient"
        android:contentDescription="@null" />

    <!-- Contenido principal -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp">

        <!-- Jesús sprite — lado izquierdo -->
        <ImageView
            android:id="@+id/widget_jesus_image"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:scaleType="fitCenter"
            android:contentDescription="Jesús" />

        <!-- Streak counter: icono fuego + número + labels + badge Hoy -->
        <LinearLayout
            android:id="@+id/widget_streak_block"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/widget_jesus_image"
            android:layout_marginTop="8dp"
            android:layout_marginStart="2dp"
            android:orientation="horizontal"
            android:gravity="bottom">

            <!-- Icono fuego (tintable desde Kotlin, igual que in-app) -->
            <ImageView
                android:id="@+id/widget_fire_icon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:src="@drawable/ic_fire"
                android:contentDescription="@null" />

            <!-- Número grande de racha -->
            <TextView
                android:id="@+id/widget_streak_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0"
                android:textColor="#FFFFFFFF"
                android:textSize="48sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:includeFontPadding="false"
                android:shadowColor="#66000000"
                android:shadowDx="2"
                android:shadowDy="3"
                android:shadowRadius="6" />

            <!-- DÍAS / DE VICTORIA apilado -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="10dp"
                android:layout_gravity="bottom"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_streak_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DÍAS"
                    android:textColor="#FF69F0AE"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:includeFontPadding="false"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/widget_streak_sublabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-2dp"
                    android:text="DE VICTORIA"
                    android:textColor="#99FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:includeFontPadding="false" />

            </LinearLayout>

            <!-- Badge "✓ Hoy" (visible solo cuando completedToday) -->
            <TextView
                android:id="@+id/widget_hoy_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="12dp"
                android:layout_gravity="bottom"
                android:background="@drawable/jesus_hoy_badge_bg"
                android:paddingStart="7dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="✓ Hoy"
                android:textColor="#FF4CAF50"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Mensaje motivacional — max 3 líneas como in-app -->
        <TextView
            android:id="@+id/widget_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/widget_jesus_image"
            android:layout_below="@id/widget_streak_block"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="10dp"
            android:text=""
            android:textColor="#E6FFFFFF"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="3"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.15"
            android:shadowColor="#88000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <!-- Botón de acción — pill dorado centrado, igual que in-app -->
        <TextView
            android:id="@+id/widget_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_alignParentBottom="true"
            android:background="@drawable/jesus_badge_background"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Empieza hoy"
            android:textColor="#FFD4AF37"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

    </RelativeLayout>
</FrameLayout>
