<?xml version="1.0" encoding="utf-8"?>
<!-- Widget 4x2 para Versículo del Día -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/verse_widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <LinearLayout
        android:id="@+id/verse_widget_inner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="@drawable/widget_bg_dark"
        android:gravity="center_vertical">

        <!-- Etiqueta superior -->
        <TextView
            android:id="@+id/verse_widget_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/verse_widget_label"
            android:textSize="10sp"
            android:textColor="#B0B0B0"
            android:letterSpacing="0.15"
            android:textAllCaps="true"
            android:maxLines="1" />

        <!-- Texto del versículo -->
        <TextView
            android:id="@+id/verse_widget_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/verse_widget_default_text"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:fontFamily="serif"
            android:maxLines="4"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.3" />

        <!-- Referencia -->
        <TextView
            android:id="@+id/verse_widget_reference"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/verse_widget_default_ref"
            android:textSize="11sp"
            android:textColor="#D4AF37"
            android:textStyle="bold"
            android:maxLines="1" />

    </LinearLayout>

</FrameLayout>
