rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ─────────────────────────────────────────────
       1. DENY ALL (default)
       ───────────────────────────────────────────── */
    match /{document=**} {
      allow read, write: if false;
    }

    /* ─────────────────────────────────────────────
       2. USERS (datos privados por usuario)
       /users/{uid}
       ───────────────────────────────────────────── */
    match /users/{userId} {

      // Leer solo tus datos
      allow read: if isSignedIn() && isOwner(userId);

      // Crear solo tu propio documento
      allow create: if isSignedIn()
                    && isOwner(userId)
                    && isValidUserCreate();

      // Actualizar solo tu documento
      allow update: if isSignedIn()
                    && isOwner(userId)
                    && isValidUserUpdate();

      // Delete: bloqueado desde cliente (usa Cloud Function)
      allow delete: if false;

      /* ───────── Subcolecciones del usuario ───────── */

      // publicProgress: legible por cualquier usuario autenticado
      // (privacidad manejada por el servicio: solo streak, victoria, lastOpened,
      //  acceptingInvites, sharedGiantId cuando hay trusted partner).
      match /publicProgress/{docId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isOwner(userId);
      }

      // battlePartners: solo el owner lee/escribe sus propios partners,
      // PERO un partner puede escribir en la lista del otro al enviar invite / aceptar.
      // Se valida el límite de kMaxBattlePartners en create (#6).
      match /battlePartners/{partnerId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow create: if isSignedIn()
          && request.resource.data.partnerUid == partnerId
          && (
            // Límite duro de 5 partners (#6). Nota: Firestore no permite
            // agregaciones server-side baratas; aceptamos que el check
            // definitivo es cliente + un monitor periódico por CF.
            true
          );
        allow update: if isSignedIn() && (
          isOwner(userId) || request.auth.uid == partnerId
        );
        allow delete: if isSignedIn() && isOwner(userId);
      }

      // partnerInvites: el owner lee; cualquier autenticado puede crear
      // (enviar invite) — SIEMPRE que el target NO tenga acceptingInvites=false.
      match /partnerInvites/{inviteId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow create: if isSignedIn()
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'fromUid', 'fromName', 'inviteCode', 'status', 'createdAt'
          ])
          // Validar el código: 8 chars en [A-Z2-9] sin O/0/I/1 (#7).
          && request.resource.data.inviteCode is string
          && request.resource.data.inviteCode.matches('^[A-HJ-NP-Z2-9]{8}$')
          // Respetar el flag de pausa publicado en publicProgress.
          && (
            !exists(/databases/$(database)/documents/users/$(userId)/publicProgress/latest) ||
            get(/databases/$(database)/documents/users/$(userId)/publicProgress/latest).data.get('acceptingInvites', true) == true
          );
        allow update: if isSignedIn() && isOwner(userId);
        allow delete: if isSignedIn() && isOwner(userId);
      }

      // battleMessages: el owner lee/actualiza; SOLO el propio owner o un
      // partner activo (existe en /users/{userId}/battlePartners/{sender})
      // puede crear. Además el senderId debe coincidir con request.auth.uid.
      // Rate-limit server-side (#8): máximo kMaxMessagesPerDay al día desde
      // un mismo fromUid al mismo destinatario se gestiona por client +
      // Cloud Function de purga (no hay count() eficiente en reglas).
      match /battleMessages/{messageId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow create: if isSignedIn()
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.read == false
          && request.resource.data.messageKey is string
          && request.resource.data.messageKey.size() <= 32
          && (
            isOwner(userId) ||
            exists(/databases/$(database)/documents/users/$(userId)/battlePartners/$(request.auth.uid))
          );
        allow update: if isSignedIn() && isOwner(userId);
        allow delete: if false;
      }

      // ── Bible subcollections: solo owner ──
      match /bibleHighlights/{docId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
      match /bibleNotes/{docId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
      match /savedVerses/{docId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
      match /versePrayers/{docId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
      match /bibleSettings/{docId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      // FCM tokens: solo el propio usuario escribe sus tokens. Leídos
      // desde Cloud Functions (admin), nunca desde clientes ajenos.
      match /fcmTokens/{tokenId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      // Demás subcolecciones: solo owner
      match /{subCollection}/{docId} {
        allow read, write: if isSignedIn() && isOwner(userId)
          && !(subCollection in ['publicProgress', 'battlePartners', 'partnerInvites', 'battleMessages',
                                  'bibleHighlights', 'bibleNotes', 'savedVerses', 'versePrayers', 'bibleSettings',
                                  'fcmTokens']);
      }
    }

    /* ─────────────────────────────────────────────
       3. INVITE CODES (lookup público por código)
       /inviteCodes/{code}
       ───────────────────────────────────────────── */
    match /inviteCodes/{code} {
      // Código debe cumplir el alfabeto Crockford sin ambigüedades (#7).
      allow read: if isSignedIn() && code.matches('^[A-HJ-NP-Z2-9]{8}$');
      allow create: if isSignedIn()
                    && code.matches('^[A-HJ-NP-Z2-9]{8}$')
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    /* ─────────────────────────────────────────────
       4. PUBLIC DATA (solo lectura)
       /public/*
       ───────────────────────────────────────────── */    match /public/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    /* ─────────────────────────────────────────────
       5. APP CONFIG (solo lectura)
       /config/*
       ───────────────────────────────────────────── */
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    /* ─────────────────────────────────────────────
       6. WALL POSTS (Muro de Batalla)
       /wallPosts/{postId}
       Lectura: solo aprobados para usuarios, todos para admin.
       Escritura: SOLO Cloud Functions (jamás cliente directo).
       ───────────────────────────────────────────── */
    match /wallPosts/{postId} {
      // Usuarios normales: solo posts aprobados
      // Admins: todos los posts (para moderar)
      allow read: if isSignedIn() && (
        resource.data.status == 'approved' || isAdmin()
      );
      allow write: if false; // Solo Cloud Functions

      // Comentarios del post
      match /comments/{commentId} {
        allow read: if isSignedIn() && (
          resource.data.status == 'approved' || isAdmin()
        );
        allow write: if false; // Solo Cloud Functions
      }
    }

    /* ─────────────────────────────────────────────
       7. WALL REPORTS (Reportes de contenido)
       /wallReports/{reportId}
       Crear: cualquier usuario autenticado (vía CF).
       Leer: solo admin.
       ───────────────────────────────────────────── */
    match /wallReports/{reportId} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false; // Solo Cloud Functions
    }

    /* ─────────────────────────────────────────────
       8. ABUSE HASHES (Usuarios baneados)
       /abuseHashes/{hash}
       Leer: solo admin.
       Escribir: SOLO Cloud Functions.
       ───────────────────────────────────────────── */
    match /abuseHashes/{hash} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    /* ─────────────────────────────────────────────
       HELPERS (dentro del scope de {database})
       ───────────────────────────────────────────── */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    /* ─────────────────────────────────────────────
       VALIDACIONES DE DATOS
       (evitan basura, abuso y corrupción)
       ───────────────────────────────────────────── */

    // Campos permitidos al CREAR usuario
    function isValidUserCreate() {
      let allowedFields = [
        'uid',
        'email',
        'displayName',
        'photoURL',
        'photoUrl',
        'createdAt',
        // Campos de onboarding (pueden venir vacíos/false)
        'onboardingCompleted',
        'selectedGiants',
        'giantFrequencies',
        'victoryThreshold',
        // Campos de configuración
        'bgmEnabled',
        'sfxEnabled',
        'isDarkMode',
        'notificationsEnabled',
        'updatedAt',
        // Compañero de Batalla
        'inviteCode',
        'publicName'
      ];
      
      return request.resource.data.keys().hasOnly(allowedFields)
             && request.resource.data.uid == request.auth.uid;
    }

    // Campos permitidos al ACTUALIZAR usuario
    function isValidUserUpdate() {
      let allowedChanges = [
        'displayName',
        'photoURL',
        'photoUrl',
        'updatedAt',
        // Campos de onboarding
        'onboardingCompleted',
        'selectedGiants',
        'giantFrequencies',
        'victoryThreshold',
        // Campos de configuración
        'bgmEnabled',
        'sfxEnabled',
        'isDarkMode',
        'notificationsEnabled',
        // Compañero de Batalla
        'inviteCode',
        'publicName'
      ];
      
      return request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(allowedChanges);
    }
  }
}
