rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ─────────────────────────────────────────────
       1. DENY ALL (default)
       ───────────────────────────────────────────── */
    match /{document=**} {
      allow read, write: if false;
    }

    /* ─────────────────────────────────────────────
       2. USERS (datos privados por usuario)
       /users/{uid}
       ───────────────────────────────────────────── */
    match /users/{userId} {

      // Leer solo tus datos
      allow read: if isSignedIn() && isOwner(userId);

      // Crear solo tu propio documento
      allow create: if isSignedIn()
                    && isOwner(userId)
                    && isValidUserCreate();

      // Actualizar solo tu documento
      allow update: if isSignedIn()
                    && isOwner(userId)
                    && isValidUserUpdate();

      // Delete: bloqueado desde cliente (usa Cloud Function)
      allow delete: if false;

      /* ───────── Subcolecciones del usuario ───────── */

      // publicProgress: legible solo por el owner o por partners ACTIVOS
      // (H10). Antes era legible por cualquier autenticado que conociera
      // el uid, lo que filtraba racha/sharedGiantId/lastOpened a terceros.
      match /publicProgress/{docId} {
        allow read: if isSignedIn() && (
          isOwner(userId) ||
          (
            exists(/databases/$(database)/documents/users/$(userId)/battlePartners/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(userId)/battlePartners/$(request.auth.uid)).data.status == 'active'
          )
        );
        allow write: if isSignedIn() && isOwner(userId);
      }

      // battlePartners: solo el owner lee/escribe sus propios partners.
      // El compañero (uid==partnerId) puede UPDATE únicamente para cambiar
      // su `status` (p.ej. pausar/activar) o los timestamps relacionados;
      // no puede tocar `partnerUid`, `partnerName`, `addedAt` ni inyectar
      // campos arbitrarios (H5).
      match /battlePartners/{partnerId} {
        allow read: if isSignedIn() && isOwner(userId);
        // Creates are only allowed through Cloud Functions so partner limits
        // and reciprocal state cannot be skipped by modified clients.
        allow create: if false;
        allow update: if isSignedIn() && (
          isOwner(userId) ||
          (
            request.auth.uid == partnerId &&
            request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasOnly(['status', 'updatedAt', 'pausedAt']) &&
            (
              !('status' in request.resource.data.diff(resource.data).affectedKeys()) ||
              request.resource.data.status in ['active', 'paused', 'inactive']
            )
          )
        );
        allow delete: if isSignedIn() && isOwner(userId);
      }

      // partnerInvites: el owner lee y administra su bandeja; crear invitaciones
      // ocurre solo vía Cloud Function para aplicar límites y validaciones.
      match /partnerInvites/{inviteId} {
        allow read: if isSignedIn() && isOwner(userId);
        // Creates are only allowed through Cloud Functions. The callable
        // verifies invite code format, paused invites, duplicate links, and
        // max partner limits transactionally.
        allow create: if false;
        allow update: if isSignedIn() && isOwner(userId);
        allow delete: if isSignedIn() && isOwner(userId);
      }

      // battleMessages: el owner lee/actualiza; los creates pasan por Cloud
      // Functions para validar compañero activo mutuo y rate-limit diario.
      // Creates are only allowed through Cloud Functions to enforce daily
      // message/SOS limits and mutual active partner checks server-side.
      match /battleMessages/{messageId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow create: if false;
        allow update: if isSignedIn() && isOwner(userId);
        allow delete: if false;
      }

      // ── Bible subcollections: solo owner ──
      match /bibleHighlights/{docId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
      match /bibleNotes/{docId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
      match /savedVerses/{docId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
      match /versePrayers/{docId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
      match /bibleSettings/{docId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      // FCM tokens: solo el propio usuario escribe sus tokens. Leídos
      // desde Cloud Functions (admin), nunca desde clientes ajenos.
      match /fcmTokens/{tokenId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      // Demás subcolecciones: solo owner
      match /{subCollection}/{docId} {
        allow read, write: if isSignedIn() && isOwner(userId)
          && !(subCollection in ['publicProgress', 'battlePartners', 'partnerInvites', 'battleMessages',
                                  'bibleHighlights', 'bibleNotes', 'savedVerses', 'versePrayers', 'bibleSettings',
                                  'fcmTokens']);
      }
    }

    /* ─────────────────────────────────────────────
       3. INVITE CODES (lookup público por código)
       /inviteCodes/{code}
       ───────────────────────────────────────────── */
    match /inviteCodes/{code} {
      // Código debe cumplir el alfabeto Crockford sin ambigüedades (#7).
      allow read: if isSignedIn() && code.matches('^[A-HJ-NP-Z2-9]{8}$');
      allow create: if isSignedIn()
                    && code.matches('^[A-HJ-NP-Z2-9]{8}$')
                    && request.resource.data.uid == request.auth.uid;
      // H6: uid es inmutable. Sólo permitimos cambiar el publicName y
      // marcas de tiempo. Así un cliente modificado no puede secuestrar
      // el código apuntándolo a otro uid.
      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['publicName', 'updatedAt']);
      allow delete: if false;
    }

    /* ─────────────────────────────────────────────
       4. PUBLIC DATA (solo lectura)
       /public/*
       ───────────────────────────────────────────── */    match /public/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    /* ─────────────────────────────────────────────
       5. APP CONFIG (solo lectura)
       /config/*
       ───────────────────────────────────────────── */
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    /* ─────────────────────────────────────────────
       6. WALL POSTS (Muro de Batalla)
       /wallPosts/{postId}
       Lectura: solo aprobados para usuarios, todos para admin.
       Escritura: SOLO Cloud Functions (jamás cliente directo).
       ───────────────────────────────────────────── */
    match /wallPosts/{postId} {
      // Usuarios normales: solo posts aprobados
      // Admins: todos los posts (para moderar)
      allow read: if isSignedIn() && (
        resource.data.status == 'approved' || isAdmin()
      );
      allow write: if false; // Solo Cloud Functions

      // Comentarios del post
      match /comments/{commentId} {
        allow read: if isSignedIn() && (
          resource.data.status == 'approved' || isAdmin()
        );
        allow write: if false; // Solo Cloud Functions
      }
    }

    /* ─────────────────────────────────────────────
       7. WALL REPORTS (Reportes de contenido)
       /wallReports/{reportId}
       Crear: cualquier usuario autenticado (vía CF).
       Leer: solo admin.
       ───────────────────────────────────────────── */
    match /wallReports/{reportId} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false; // Solo Cloud Functions
    }

    /* ─────────────────────────────────────────────
       8. ABUSE HASHES (Usuarios baneados)
       /abuseHashes/{hash}
       Leer: solo admin.
       Escribir: SOLO Cloud Functions.
       ───────────────────────────────────────────── */
    match /abuseHashes/{hash} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    /* ─────────────────────────────────────────────
       9. STUDY ROOMS (Modo Estudio Colaborativo)
       /studyRooms/{code}
       Lectura: solo miembros (uid en members) o admin.
       Escritura: SOLO Cloud Functions (createStudyRoom,
       joinStudyRoom, leaveStudyRoom, rotateStudyVersions).
       ───────────────────────────────────────────── */
    match /studyRooms/{code} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (resource.data.members[request.auth.uid] != null)
      );
      allow write: if false; // Solo Cloud Functions
    }

    /* ─────────────────────────────────────────────
       HELPERS (dentro del scope de {database})
       ───────────────────────────────────────────── */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    /* ─────────────────────────────────────────────
       VALIDACIONES DE DATOS
       (evitan basura, abuso y corrupción)
       ───────────────────────────────────────────── */

    // Campos permitidos al CREAR usuario
    function isValidUserCreate() {
      let allowedFields = [
        'uid',
        'email',
        'displayName',
        'photoURL',
        'photoUrl',
        'createdAt',
        // Campos de onboarding (pueden venir vacíos/false)
        'onboardingCompleted',
        'selectedGiants',
        'giantFrequencies',
        'victoryThreshold',
        // Campos de configuración
        'bgmEnabled',
        'sfxEnabled',
        'isDarkMode',
        'notificationsEnabled',
        'updatedAt',
        // Compañero de Batalla
        'inviteCode',
        'publicName'
      ];
      
      return request.resource.data.keys().hasOnly(allowedFields)
             && request.resource.data.uid == request.auth.uid;
    }

    // Campos permitidos al ACTUALIZAR usuario
    function isValidUserUpdate() {
      let allowedChanges = [
        'displayName',
        'photoURL',
        'photoUrl',
        'updatedAt',
        // Campos de onboarding
        'onboardingCompleted',
        'selectedGiants',
        'giantFrequencies',
        'victoryThreshold',
        // Campos de configuración
        'bgmEnabled',
        'sfxEnabled',
        'isDarkMode',
        'notificationsEnabled',
        // Compañero de Batalla
        'inviteCode',
        'publicName'
      ];
      
      return request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(allowedChanges);
    }
  }
}
