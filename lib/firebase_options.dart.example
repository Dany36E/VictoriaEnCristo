import 'package:firebase_core/firebase_core.dart' show FirebaseOptions;
import 'package:flutter/foundation.dart'
    show defaultTargetPlatform, kIsWeb, TargetPlatform;

/// Stub usado solo por CI / nuevos clones del repo.
/// Reemplaza este archivo con el real generado por `flutterfire configure`
/// para builds locales y de release. Este stub permite que `flutter analyze`
/// y `flutter test` funcionen sin exponer las credenciales reales.
class DefaultFirebaseOptions {
  static FirebaseOptions get currentPlatform {
    if (kIsWeb) return web;
    switch (defaultTargetPlatform) {
      case TargetPlatform.android:
        return android;
      case TargetPlatform.iOS:
        return ios;
      case TargetPlatform.macOS:
        return macos;
      case TargetPlatform.windows:
        return windows;
      default:
        throw UnsupportedError(
          'DefaultFirebaseOptions stub no soporta esta plataforma.',
        );
    }
  }

  static const FirebaseOptions web = FirebaseOptions(
    apiKey: 'stub',
    appId: '1:0:web:stub',
    messagingSenderId: '0',
    projectId: 'stub-project',
  );

  static const FirebaseOptions android = FirebaseOptions(
    apiKey: 'stub',
    appId: '1:0:android:stub',
    messagingSenderId: '0',
    projectId: 'stub-project',
  );

  static const FirebaseOptions ios = FirebaseOptions(
    apiKey: 'stub',
    appId: '1:0:ios:stub',
    messagingSenderId: '0',
    projectId: 'stub-project',
    iosBundleId: 'com.victoriaencristo.app',
  );

  static const FirebaseOptions macos = ios;
  static const FirebaseOptions windows = web;
}
